# Admin mestre (opcional) — login em /admin/login com qualquer utilizador + esta senha
# AAMIHE_ADMIN_SECRET=

# Supabase (obrigatório para uploads persistentes na Vercel)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# Vercel Blob — dashboard JSON em produção (Storage → Blob no painel Vercel)
# BLOB_STORE_ID=store_xxx   # só referência; o código usa o token abaixo
BLOB_READ_WRITE_TOKEN=

# Notificações por email (opcional — Resend)
# RESEND_API_KEY=
# SITE_EMAIL_FROM=AAMIHE <noreply@aamihe.com>
# SITE_NOTIFY_EMAIL=geral@aamihe.com
