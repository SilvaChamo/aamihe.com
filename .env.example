# Supabase AAMIHE — Hetzner (infra Visual Design)
NEXT_PUBLIC_SUPABASE_URL=https://supabase.visualdesignmoz.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_hetzner
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_hetzner

# Schema Postgres (no servidor Hetzner, após install.sh):
#   scripts/supabase-hetzner/aamihe-init.sql
#   scripts/supabase-hetzner/aamihe-documents-notifications.sql
#   scripts/supabase-hetzner/aamihe-email-quota.sql

# E-mail — Brevo SMTP relay (ou DirectAdmin)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_login@smtp-brevo.com
SMTP_PASS=sua_smtp_pass
SITE_EMAIL_FROM=AAMIHE <geral@aamihe.com>
SITE_NOTIFY_EMAIL=geral@aamihe.com
EMAIL_DAILY_SEND_LIMIT=50

# Site
NEXT_PUBLIC_SITE_URL=https://aamihe.com

# Google OAuth — login «Entrar com Google»
# URIs de redireccionamento autorizados no Google Cloud Console (Credentials → OAuth client):
#   https://aamihe.com/api/auth/google/callback
#   https://app.aamihe.com/api/auth/google/callback
#   https://aamihe.vercel.app/api/auth/google/callback
#   http://localhost:3004/api/auth/google/callback
# No Supabase Hetzner (GoTrue): scripts/supabase-hetzner/configure-google-oauth.sh
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret

# Admin mestre (opcional, login local)
# AAMIHE_ADMIN_SECRET=
