# Supabase AAMIHE — cloud (activo) ou Hetzner (migração)
NEXT_PUBLIC_SUPABASE_URL=https://gwankhxcbkrtgxopbxwd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# Migração cloud → Hetzner (temporário, em .env.local)
# SUPABASE_CLOUD_URL=https://gwankhxcbkrtgxopbxwd.supabase.co
# SUPABASE_HETZNER_URL=https://supabase.visualdesignmoz.com
# SUPABASE_HETZNER_SERVICE_ROLE_KEY=...

# Schema (no Postgres Hetzner, após install.sh):
#   scripts/supabase-hetzner/aamihe-init.sql
#   scripts/supabase-hetzner/aamihe-documents-notifications.sql
#   scripts/supabase-hetzner/aamihe-email-quota.sql
# Migrar dados legados (uma vez): npm run migrate-all-to-supabase

# E-mail — SMTP DirectAdmin / Hetzner (Vercel: mail.aamihe.com:587)
SMTP_HOST=mail.aamihe.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@aamihe.com
SMTP_PASS=palavra-passe-noreply
SMTP_GERAL_USER=geral@aamihe.com
SMTP_GERAL_PASS=palavra-passe-geral
SITE_EMAIL_FROM=AAMIHE <noreply@aamihe.com>
SITE_NOTIFY_EMAIL=geral@aamihe.com
EMAIL_DAILY_SEND_LIMIT=50

# Site
NEXT_PUBLIC_SITE_URL=https://aamihe.com

# Google OAuth — login «Entrar com Google» (redirect: /api/auth/google/callback)
# No Google Cloud Console → Credenciais → URIs de redireccionamento autorizados:
#   https://aamihe.com/api/auth/google/callback
#   http://localhost:3004/api/auth/google/callback
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
# NEXT_PUBLIC_GOOGLE_CLIENT_ID= (opcional, só se precisar no browser)
