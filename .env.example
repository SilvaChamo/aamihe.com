# Supabase — login, perfis e conteúdo (mesmo projecto que visualdesign)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# Executar uma vez no SQL Editor: scripts/supabase-aamihe-profiles.sql
# Migrar utilizadores do JSON legado: npm run migrate-users

# Google OAuth — mesmo provider do visualdesign (projecto Supabase partilhado).
# Redirect URLs: https://aamihe.com/auth/callback e http://localhost:3004/auth/callback
# Só entram contas com perfil em aamihe_user_profiles (registo ou migração).
# VisualDESIGN: recusar login se existir perfil AAMIHE sem perfil visualdesign.

# Vercel Blob — dashboard JSON em produção (Storage → Blob no painel Vercel)
# BLOB_STORE_ID=store_xxx   # só referência; o código usa o token abaixo
BLOB_READ_WRITE_TOKEN=

# E-mail — SMTP DirectAdmin / Hetzner (Vercel: mail.aamihe.com:587)
SMTP_HOST=mail.aamihe.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@aamihe.com
SMTP_PASS=palavra-passe-da-conta
SITE_EMAIL_FROM=AAMIHE <noreply@aamihe.com>
SITE_NOTIFY_EMAIL=geral@aamihe.com
EMAIL_DAILY_SEND_LIMIT=50

# Site
# NEXT_PUBLIC_SITE_URL=https://aamihe.com
